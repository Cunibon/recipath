{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecipeImportSchema",
  "type": "object",
  "description": "Full schema for BYOK Recipe Scanner. Captures recipe structure, timers, nutritional data, and accurate tags. CRITICAL: All string values must be valid JSON. Never use unescaped double-quote characters inside string values. Replace inch marks with the word 'inch' (e.g. write '1/4 inch strips' instead of using the double-quote character as an inch symbol).",
  "required": ["recipes", "groceries", "recipeTags"],
  "properties": {
    "recipes": {
      "type": "array",
      "description": "List of recipes to import.",
      "items": {
        "type": "object",
        "required": ["id", "title", "steps", "servings"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique recipe ID (e.g. 'RECIPE_001')."
          },
          "title": {
            "type": "string"
          },
          "servings": {
            "type": "integer",
            "nullable": true,
            "description": "Number of servings."
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description", "ingredients"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Unique step ID."
                },
                "description": {
                  "type": "string",
                  "description": "Plain text step description. Each step should focus on a single coherent task — do not chain unrelated actions together. Break compound steps into multiple smaller steps. NEVER use the double-quote character inside this value. Replace inch marks with the word 'inch' (e.g. '1/4 inch strips'). Escape any special JSON characters."
                },
                "minutes": {
                  "type": "integer",
                  "nullable": true,
                  "description": "Duration of the step in minutes. Only set for longer passive/unattended steps where the cook might walk away (e.g. baking, simmering, resting, marinating). Do NOT set for short active tasks like sauteing or stirring. Set to null if no timer is needed."
                },
                "ingredients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "amount", "unit", "groceryId"],
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Unique ingredient ID."
                      },
                      "amount": {
                        "type": "number"
                      },
                      "groceryId": {
                        "type": "string",
                        "description": "Must strictly match a grocery id in the 'groceries' array."
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "Milliliter",
                          "Liter",
                          "Teaspoon",
                          "Tablespoon",
                          "Cup",
                          "Gram",
                          "Kilogram",
                          "Ounce",
                          "Pound",
                          "Pinch",
                          "Clove",
                          "Can",
                          "Piece"
                        ]
                      },
                      "uploaded": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "groceries": {
      "type": "array",
      "description": "List of groceries referenced in recipes. Contains nutrition per 100g.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "unit",
          "conversionAmount",
          "conversionUnit"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique grocery ID (e.g. 'GROCERY_001')."
          },
          "name": {
            "type": "string"
          },
          "unit": {
            "type": "string",
            "enum": [
              "Milliliter",
              "Liter",
              "Teaspoon",
              "Tablespoon",
              "Cup",
              "Gram",
              "Kilogram",
              "Ounce",
              "Pound",
              "Pinch",
              "Clove",
              "Can",
              "Piece"
            ]
          },
          "conversionAmount": {
            "type": "number",
            "description": "Density conversion: The equivalent amount in 'conversionUnit' for 1 unit of this item (e.g. 1 Cup Flour = 120g)."
          },
          "conversionUnit": {
            "type": "string",
            "description": "Target unit for the conversionAmount. MUST be a different type than 'unit': if unit is Volume (Milliliter, Liter, Teaspoon, Tablespoon, Cup), conversionUnit MUST be Weight (Gram, Kilogram, Ounce, Pound). If unit is Weight, conversionUnit MUST be Volume. Miscellaneous units (Pinch, Clove, Can, Piece) default to Gram for conversion.",
            "enum": [
              "Milliliter",
              "Liter",
              "Teaspoon",
              "Tablespoon",
              "Cup",
              "Gram",
              "Kilogram",
              "Ounce",
              "Pound"
            ]
          },
          "kcal": {
            "type": "number",
            "nullable": true,
            "description": "Calories per 100g"
          },
          "fat": {
            "type": "number",
            "nullable": true,
            "description": "Fat (g) per 100g"
          },
          "carbs": {
            "type": "number",
            "nullable": true,
            "description": "Carbohydrates (g) per 100g"
          },
          "protein": {
            "type": "number",
            "nullable": true,
            "description": "Protein (g) per 100g"
          },
          "fiber": {
            "type": "number",
            "nullable": true,
            "description": "Fiber (g) per 100g"
          },
          "uploaded": {
            "type": "boolean"
          }
        }
      }
    },
    "recipeTags": {
      "type": "array",
      "description": "List of recipe-tag associations.",
      "items": {
        "type": "object",
        "required": ["recipeId", "tags"],
        "properties": {
          "recipeId": {
            "type": "string",
            "description": "The ID of the recipe from the 'recipes' array."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "description", "color"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string",
                  "description": "e.g. 'Main course', 'Vegetarian'. Must be accurate to the specific recipe."
                },
                "description": {
                  "type": "string",
                  "description": "Short plain text description of the tag. NEVER use the double-quote character inside this value. Replace inch marks with the word 'inch' (e.g. '1/4 inch strips'). Escape any special JSON characters."
                },
                "color": {
                  "type": "integer",
                  "description": "ARGB color value (e.g. 4291580529)."
                },
                "deleted": {
                  "type": "boolean"
                },
                "uploaded": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}
